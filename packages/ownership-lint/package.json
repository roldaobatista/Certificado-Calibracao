{
  "name": "@afere/ownership-lint",
  "version": "0.0.1",
  "private": true,
  "description": "Gate 6 — lint de ownership de domínio. Detecta imports proibidos: web/portal/android não podem importar normative-rules nem engine-uncertainty.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ownership-lint": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/rules.yaml','dist/rules.yaml');require('fs').chmodSync('dist/cli.js',0o755)\"",
    "dev": "tsx watch src/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsx src/cli.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "fast-glob": "^3.3.2",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
