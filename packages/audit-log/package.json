{
  "name": "@afere/audit-log",
  "version": "0.0.1",
  "private": true,
  "description": "Verificação de trilha imutável append-only com hash-chain (owner: db-schema + lgpd-security)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "audit-chain-verify": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/cli.js',0o755)\"",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/*.test.ts",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
