{
  "name": "@afere/normative-rules",
  "version": "0.0.1",
  "private": true,
  "description": "Regras normativas (DOQ-CGCRE, NIT-DICLA, Portaria Inmetro 157/2022, ILAC P10/G8, RTM) interpretadas como código. Owner: regulator. Library — consumida APENAS por apps/api.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/*.test.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.2",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  }
}
