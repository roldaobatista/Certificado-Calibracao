{
  "name": "@afere/db",
  "version": "0.0.1",
  "private": true,
  "description": "Schema Postgres + Prisma client do Aferê (owner: db-schema)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm exec prisma generate --no-engine && tsc",
    "dev": "tsc --watch",
    "typecheck": "pnpm exec prisma generate --no-engine && tsc --noEmit",
    "prisma:generate": "pnpm exec prisma generate",
    "prisma:migrate:dev": "pnpm exec prisma migrate dev",
    "prisma:migrate:deploy": "pnpm exec prisma migrate deploy",
    "seed": "pnpm exec prisma generate && tsx prisma/seed.ts",
    "prisma:studio": "pnpm exec prisma studio",
    "clean": "rm -rf dist .turbo node_modules/.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
