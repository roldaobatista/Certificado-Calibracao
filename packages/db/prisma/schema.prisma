// Schema Aferê — Postgres + Prisma
//
// Owner: db-schema (co-owner audit_log: lgpd-security)
// Governed by: harness/05-guardrails.md (Gates 1, 2, 3, 4)
// Referências: PRD §6.5, §7.10, §11
//
// V1 foundation. O nucleo abaixo materializa organizacoes, usuarios,
// sessoes, competencias e onboarding multitenant com organization_id
// explicito para os gates de tenancy.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"]
}

model HealthCheck {
  id        String   @id @default(uuid()) @db.Uuid
  component String   @db.VarChar(64)
  ok        Boolean
  checkedAt DateTime @default(now()) @map("checked_at") @db.Timestamptz(6)

  @@map("health_check")
  @@schema("public")
}

model Organization {
  id                      String            @id @default(uuid()) @db.Uuid
  slug                    String            @unique @db.VarChar(64)
  legalName               String            @map("legal_name") @db.VarChar(160)
  regulatoryProfile       String            @default("type_b") @map("regulatory_profile") @db.VarChar(32)
  normativePackageVersion String            @default("2026-04-20-baseline-v0.1.0") @map("normative_package_version") @db.VarChar(80)
  createdAt               DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  users                   AppUser[]
  sessions                AppSession[]
  competencies            UserCompetency[]
  onboardingState         OnboardingState?
  customers               Customer[]
  standards               Standard[]
  standardCalibrations    StandardCalibration[]
  procedures              ProcedureRevision[]
  equipment               Equipment[]
  registryAuditEvents     RegistryAuditEvent[]
  serviceOrders           ServiceOrder[]
  certificatePublications CertificatePublication[]
  emissionAuditEvents     EmissionAuditEvent[]
  nonconformities         Nonconformity[]
  nonconformingWorkCases  NonconformingWorkCase[]
  internalAuditCycles     InternalAuditCycle[]
  managementReviewMeetings ManagementReviewMeeting[]
  complianceProfile       OrganizationComplianceProfile?

  @@map("organizations")
  @@schema("public")
}

model AppUser {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  email          String           @unique @db.VarChar(255)
  passwordHash   String           @map("password_hash")
  displayName    String           @map("display_name") @db.VarChar(140)
  roles          String[]         @default([])
  status         String           @default("active") @db.VarChar(24)
  teamName       String?          @map("team_name") @db.VarChar(120)
  mfaEnforced    Boolean          @default(false) @map("mfa_enforced")
  mfaEnrolled    Boolean          @default(false) @map("mfa_enrolled")
  deviceCount    Int              @default(0) @map("device_count")
  lastLoginAt    DateTime?        @map("last_login_at") @db.Timestamptz(6)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  competencies   UserCompetency[]
  sessions       AppSession[]
  registryEvents RegistryAuditEvent[] @relation("RegistryEventActor")
  executedServiceOrders ServiceOrder[] @relation("ServiceOrderExecutor")
  reviewedServiceOrders ServiceOrder[] @relation("ServiceOrderReviewer")
  signedServiceOrders ServiceOrder[]   @relation("ServiceOrderSignatory")
  emissionAuditEvents EmissionAuditEvent[] @relation("EmissionAuditEventActor")
  ownedNonconformities Nonconformity[]

  @@index([organizationId, status])
  @@map("app_users")
  @@schema("public")
}

model UserCompetency {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  instrumentType String       @map("instrument_type") @db.VarChar(80)
  roleLabel      String       @map("role_label") @db.VarChar(120)
  status         String       @db.VarChar(24)
  validUntil     DateTime     @map("valid_until") @db.Date
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user           AppUser      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
  @@map("user_competencies")
  @@schema("public")
}

model AppSession {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  tokenHash      String       @unique @map("token_hash")
  expiresAt      DateTime     @map("expires_at") @db.Timestamptz(6)
  revokedAt      DateTime?    @map("revoked_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user           AppUser      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
  @@index([expiresAt])
  @@map("app_sessions")
  @@schema("public")
}

model OnboardingState {
  id                              String       @id @default(uuid()) @db.Uuid
  organizationId                  String       @unique @map("organization_id") @db.Uuid
  startedAt                       DateTime     @map("started_at") @db.Timestamptz(6)
  completedAt                     DateTime?    @map("completed_at") @db.Timestamptz(6)
  organizationProfileCompleted    Boolean      @default(false) @map("organization_profile_completed")
  primarySignatoryReady           Boolean      @default(false) @map("primary_signatory_ready")
  certificateNumberingConfigured  Boolean      @default(false) @map("certificate_numbering_configured")
  scopeReviewCompleted            Boolean      @default(false) @map("scope_review_completed")
  publicQrConfigured              Boolean      @default(false) @map("public_qr_configured")
  createdAt                       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization                    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("onboarding_states")
  @@schema("public")
}

model Customer {
  id                     String       @id @default(uuid()) @db.Uuid
  organizationId         String       @map("organization_id") @db.Uuid
  legalName              String       @map("legal_name") @db.VarChar(160)
  tradeName              String       @map("trade_name") @db.VarChar(160)
  documentLabel          String       @map("document_label") @db.VarChar(80)
  segmentLabel           String       @map("segment_label") @db.VarChar(120)
  accountOwnerName       String       @map("account_owner_name") @db.VarChar(140)
  accountOwnerEmail      String       @map("account_owner_email") @db.VarChar(255)
  contractLabel          String       @map("contract_label")
  specialConditionsLabel String       @map("special_conditions_label")
  contactName            String       @map("contact_name") @db.VarChar(140)
  contactRoleLabel       String       @map("contact_role_label") @db.VarChar(120)
  contactEmail           String       @map("contact_email") @db.VarChar(255)
  contactPhoneLabel      String?      @map("contact_phone_label") @db.VarChar(40)
  addressLine1           String       @map("address_line1") @db.VarChar(180)
  addressCity            String       @map("address_city") @db.VarChar(80)
  addressState           String       @map("address_state") @db.VarChar(40)
  addressPostalCode      String?      @map("address_postal_code") @db.VarChar(24)
  addressCountry         String       @map("address_country") @db.VarChar(40)
  addressConditionsLabel String?      @map("address_conditions_label")
  archivedAt             DateTime?    @map("archived_at") @db.Timestamptz(6)
  createdAt              DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  equipment              Equipment[]
  serviceOrders          ServiceOrder[]

  @@index([organizationId, archivedAt])
  @@index([organizationId, tradeName])
  @@map("customers")
  @@schema("public")
}

model Standard {
  id                  String               @id @default(uuid()) @db.Uuid
  organizationId      String               @map("organization_id") @db.Uuid
  code                String               @db.VarChar(64)
  title               String               @db.VarChar(160)
  kindLabel           String               @map("kind_label") @db.VarChar(80)
  nominalClassLabel   String               @map("nominal_class_label") @db.VarChar(80)
  sourceLabel         String               @map("source_label") @db.VarChar(80)
  certificateLabel    String               @map("certificate_label") @db.VarChar(80)
  manufacturerLabel   String               @map("manufacturer_label") @db.VarChar(80)
  modelLabel          String               @map("model_label") @db.VarChar(80)
  serialNumberLabel   String               @map("serial_number_label") @db.VarChar(80)
  nominalValueLabel   String               @map("nominal_value_label") @db.VarChar(80)
  classLabel          String               @map("class_label") @db.VarChar(40)
  usageRangeLabel     String               @map("usage_range_label") @db.VarChar(120)
  measurementValue    Decimal              @map("measurement_value") @db.Decimal(18, 6)
  applicableRangeMin  Decimal              @map("applicable_range_min") @db.Decimal(18, 6)
  applicableRangeMax  Decimal              @map("applicable_range_max") @db.Decimal(18, 6)
  uncertaintyLabel    String               @map("uncertainty_label") @db.VarChar(80)
  correctionFactorLabel String             @map("correction_factor_label") @db.VarChar(80)
  hasValidCertificate Boolean              @default(true) @map("has_valid_certificate")
  certificateValidUntil DateTime?          @map("certificate_valid_until") @db.Date
  archivedAt          DateTime?            @map("archived_at") @db.Timestamptz(6)
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  calibrations        StandardCalibration[]
  equipment           Equipment[]          @relation("EquipmentPrimaryStandard")
  serviceOrders       ServiceOrder[]       @relation("ServiceOrderPrimaryStandard")

  @@unique([organizationId, code])
  @@index([organizationId, archivedAt])
  @@map("standards")
  @@schema("public")
}

model StandardCalibration {
  id               String       @id @default(uuid()) @db.Uuid
  organizationId   String       @map("organization_id") @db.Uuid
  standardId       String       @map("standard_id") @db.Uuid
  calibratedAt     DateTime     @map("calibrated_at") @db.Date
  laboratoryLabel  String       @map("laboratory_label") @db.VarChar(120)
  certificateLabel String       @map("certificate_label") @db.VarChar(80)
  sourceLabel      String       @map("source_label") @db.VarChar(80)
  uncertaintyLabel String       @map("uncertainty_label") @db.VarChar(80)
  validUntil       DateTime     @map("valid_until") @db.Date
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  standard         Standard     @relation(fields: [standardId], references: [id], onDelete: Cascade)

  @@index([organizationId, standardId, calibratedAt])
  @@map("standard_calibrations")
  @@schema("public")
}

model ProcedureRevision {
  id                    String       @id @default(uuid()) @db.Uuid
  organizationId        String       @map("organization_id") @db.Uuid
  code                  String       @db.VarChar(64)
  title                 String       @db.VarChar(160)
  typeLabel             String       @map("type_label") @db.VarChar(80)
  revisionLabel         String       @map("revision_label") @db.VarChar(24)
  effectiveSince        DateTime     @map("effective_since") @db.Date
  effectiveUntil        DateTime?    @map("effective_until") @db.Date
  lifecycleLabel        String       @map("lifecycle_label") @db.VarChar(60)
  usageLabel            String       @map("usage_label") @db.VarChar(160)
  scopeLabel            String       @map("scope_label")
  environmentRangeLabel String       @map("environment_range_label") @db.VarChar(160)
  curvePolicyLabel      String       @map("curve_policy_label")
  standardsPolicyLabel  String       @map("standards_policy_label")
  approvalLabel         String       @map("approval_label") @db.VarChar(160)
  relatedDocuments      String[]     @default([]) @map("related_documents")
  archivedAt            DateTime?    @map("archived_at") @db.Timestamptz(6)
  createdAt             DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  equipment             Equipment[]  @relation("EquipmentProcedure")
  serviceOrders         ServiceOrder[] @relation("ServiceOrderProcedure")

  @@unique([organizationId, code, revisionLabel])
  @@index([organizationId, code, archivedAt])
  @@map("procedure_revisions")
  @@schema("public")
}

model Equipment {
  id                    String            @id @default(uuid()) @db.Uuid
  organizationId        String            @map("organization_id") @db.Uuid
  customerId            String            @map("customer_id") @db.Uuid
  procedureId           String?           @map("procedure_id") @db.Uuid
  primaryStandardId     String?           @map("primary_standard_id") @db.Uuid
  code                  String            @db.VarChar(64)
  tagCode               String            @map("tag_code") @db.VarChar(64)
  serialNumber          String            @map("serial_number") @db.VarChar(80)
  typeModelLabel        String            @map("type_model_label") @db.VarChar(120)
  capacityClassLabel    String            @map("capacity_class_label") @db.VarChar(120)
  supportingStandardCodes String[]        @default([]) @map("supporting_standard_codes")
  addressLine1          String            @map("address_line1") @db.VarChar(180)
  addressCity           String            @map("address_city") @db.VarChar(80)
  addressState          String            @map("address_state") @db.VarChar(40)
  addressPostalCode     String?           @map("address_postal_code") @db.VarChar(24)
  addressCountry        String            @map("address_country") @db.VarChar(40)
  addressConditionsLabel String?          @map("address_conditions_label")
  lastCalibrationAt     DateTime?         @map("last_calibration_at") @db.Date
  nextCalibrationAt     DateTime?         @map("next_calibration_at") @db.Date
  archivedAt            DateTime?         @map("archived_at") @db.Timestamptz(6)
  createdAt             DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization          Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  customer              Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  procedure             ProcedureRevision? @relation("EquipmentProcedure", fields: [procedureId], references: [id], onDelete: SetNull)
  primaryStandard       Standard?         @relation("EquipmentPrimaryStandard", fields: [primaryStandardId], references: [id], onDelete: SetNull)
  serviceOrders         ServiceOrder[]

  @@unique([organizationId, code])
  @@index([organizationId, customerId, archivedAt])
  @@index([organizationId, tagCode])
  @@map("equipment")
  @@schema("public")
}

model RegistryAuditEvent {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  entityType     String       @map("entity_type") @db.VarChar(40)
  entityId       String       @map("entity_id") @db.Uuid
  action         String       @db.VarChar(40)
  actorUserId    String?      @map("actor_user_id") @db.Uuid
  summary        String       @db.VarChar(240)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  actorUser      AppUser?     @relation("RegistryEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, entityType, entityId, createdAt])
  @@map("registry_audit_events")
  @@schema("public")
}

model ServiceOrder {
  id                  String            @id @default(uuid()) @db.Uuid
  organizationId      String            @map("organization_id") @db.Uuid
  customerId          String            @map("customer_id") @db.Uuid
  equipmentId         String            @map("equipment_id") @db.Uuid
  procedureId         String            @map("procedure_id") @db.Uuid
  primaryStandardId   String            @map("primary_standard_id") @db.Uuid
  executorUserId      String            @map("executor_user_id") @db.Uuid
  reviewerUserId      String?           @map("reviewer_user_id") @db.Uuid
  signatoryUserId     String?           @map("signatory_user_id") @db.Uuid
  workOrderNumber     String            @map("work_order_number") @db.VarChar(64)
  workflowStatus      String            @map("workflow_status") @db.VarChar(32)
  environmentLabel    String            @map("environment_label") @db.VarChar(160)
  curvePointsLabel    String            @map("curve_points_label") @db.VarChar(120)
  evidenceLabel       String            @map("evidence_label") @db.VarChar(160)
  uncertaintyLabel    String            @map("uncertainty_label") @db.VarChar(120)
  conformityLabel     String            @map("conformity_label") @db.VarChar(160)
  measurementResultValue              Float?    @map("measurement_result_value")
  measurementExpandedUncertaintyValue Float?    @map("measurement_expanded_uncertainty_value")
  measurementCoverageFactor           Float?    @map("measurement_coverage_factor")
  measurementUnit                     String?   @map("measurement_unit") @db.VarChar(24)
  decisionRuleLabel                   String?   @map("decision_rule_label") @db.VarChar(160)
  decisionOutcomeLabel                String?   @map("decision_outcome_label") @db.VarChar(160)
  freeTextStatement                   String?   @map("free_text_statement")
  commentDraft        String            @default("") @map("comment_draft")
  reviewDecision      String            @default("pending") @map("review_decision") @db.VarChar(24)
  reviewDecisionComment String          @default("") @map("review_decision_comment")
  reviewDeviceId      String?           @map("review_device_id") @db.VarChar(120)
  signatureDeviceId   String?           @map("signature_device_id") @db.VarChar(120)
  signatureStatement  String?           @map("signature_statement")
  certificateNumber   String?           @map("certificate_number") @db.VarChar(64)
  certificateRevision String?           @map("certificate_revision") @db.VarChar(16)
  publicVerificationToken String?       @map("public_verification_token") @db.VarChar(80)
  documentHash        String?           @map("document_hash") @db.VarChar(128)
  qrHost              String?           @map("qr_host") @db.VarChar(160)
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  acceptedAt          DateTime?         @map("accepted_at") @db.Timestamptz(6)
  executionStartedAt  DateTime?         @map("execution_started_at") @db.Timestamptz(6)
  executedAt          DateTime?         @map("executed_at") @db.Timestamptz(6)
  reviewStartedAt     DateTime?         @map("review_started_at") @db.Timestamptz(6)
  reviewCompletedAt   DateTime?         @map("review_completed_at") @db.Timestamptz(6)
  signatureStartedAt  DateTime?         @map("signature_started_at") @db.Timestamptz(6)
  signedAt            DateTime?         @map("signed_at") @db.Timestamptz(6)
  emittedAt           DateTime?         @map("emitted_at") @db.Timestamptz(6)
  updatedAt           DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt          DateTime?         @map("archived_at") @db.Timestamptz(6)
  organization        Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  customer            Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  equipment           Equipment         @relation(fields: [equipmentId], references: [id], onDelete: Restrict)
  procedure           ProcedureRevision @relation("ServiceOrderProcedure", fields: [procedureId], references: [id], onDelete: Restrict)
  primaryStandard     Standard          @relation("ServiceOrderPrimaryStandard", fields: [primaryStandardId], references: [id], onDelete: Restrict)
  executorUser        AppUser           @relation("ServiceOrderExecutor", fields: [executorUserId], references: [id], onDelete: Restrict)
  reviewerUser        AppUser?          @relation("ServiceOrderReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)
  signatoryUser       AppUser?          @relation("ServiceOrderSignatory", fields: [signatoryUserId], references: [id], onDelete: SetNull)
  certificatePublications CertificatePublication[]
  emissionAuditEvents EmissionAuditEvent[]
  nonconformities         Nonconformity[]
  nonconformingWorkCases  NonconformingWorkCase[]

  @@unique([organizationId, workOrderNumber])
  @@unique([organizationId, certificateNumber])
  @@index([organizationId, workflowStatus, archivedAt])
  @@index([organizationId, customerId, updatedAt])
  @@index([organizationId, equipmentId, updatedAt])
  @@map("service_orders")
  @@schema("public")
}

model CertificatePublication {
  id                      String       @id @default(uuid()) @db.Uuid
  organizationId          String       @map("organization_id") @db.Uuid
  serviceOrderId          String       @map("service_order_id") @db.Uuid
  certificateNumber       String       @map("certificate_number") @db.VarChar(64)
  revision                String       @db.VarChar(16)
  publicVerificationToken String       @unique @map("public_verification_token") @db.VarChar(80)
  documentHash            String       @map("document_hash") @db.VarChar(128)
  qrHost                  String       @map("qr_host") @db.VarChar(160)
  signedAt                DateTime?    @map("signed_at") @db.Timestamptz(6)
  issuedAt                DateTime     @map("issued_at") @db.Timestamptz(6)
  supersededAt            DateTime?    @map("superseded_at") @db.Timestamptz(6)
  replacementPublicationId String?     @unique @map("replacement_publication_id") @db.Uuid
  previousCertificateHash String?      @map("previous_certificate_hash") @db.VarChar(128)
  notificationRecipient   String?      @map("notification_recipient") @db.VarChar(255)
  notificationSentAt      DateTime?    @map("notification_sent_at") @db.Timestamptz(6)
  reissueReason           String?      @map("reissue_reason") @db.VarChar(160)
  createdAt               DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  serviceOrder            ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  replacementPublication  CertificatePublication? @relation("CertificatePublicationReplacement", fields: [replacementPublicationId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  replacedPublication     CertificatePublication? @relation("CertificatePublicationReplacement")

  @@unique([organizationId, certificateNumber, revision])
  @@index([organizationId, serviceOrderId, issuedAt])
  @@index([organizationId, issuedAt])
  @@map("certificate_publications")
  @@schema("public")
}

model EmissionAuditEvent {
  id                String       @id @default(uuid()) @db.Uuid
  organizationId    String       @map("organization_id") @db.Uuid
  serviceOrderId    String       @map("service_order_id") @db.Uuid
  actorUserId       String?      @map("actor_user_id") @db.Uuid
  action            String       @db.VarChar(64)
  actorLabel        String       @map("actor_label") @db.VarChar(160)
  entityLabel       String       @map("entity_label") @db.VarChar(160)
  deviceId          String?      @map("device_id") @db.VarChar(120)
  certificateNumber String?      @map("certificate_number") @db.VarChar(64)
  metadata          Json?        @db.JsonB
  prevHash          String       @map("prev_hash") @db.VarChar(64)
  hash              String       @db.VarChar(64)
  occurredAt        DateTime     @map("occurred_at") @db.Timestamptz(6)
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  serviceOrder      ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  actorUser         AppUser?     @relation("EmissionAuditEventActor", fields: [actorUserId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([serviceOrderId, hash])
  @@index([organizationId, serviceOrderId, occurredAt])
  @@index([organizationId, action, occurredAt])
  @@map("emission_audit_events")
  @@schema("public")
}

model Nonconformity {
  id                    String        @id @default(uuid()) @db.Uuid
  organizationId        String        @map("organization_id") @db.Uuid
  serviceOrderId        String?       @map("service_order_id") @db.Uuid
  ownerUserId           String?       @map("owner_user_id") @db.Uuid
  title                 String        @db.VarChar(160)
  originLabel           String        @map("origin_label") @db.VarChar(120)
  severityLabel         String        @map("severity_label") @db.VarChar(80)
  status                String        @db.VarChar(24)
  noticeLabel           String        @map("notice_label") @db.VarChar(200)
  rootCauseLabel        String        @map("root_cause_label")
  containmentLabel      String        @map("containment_label")
  correctiveActionLabel String        @map("corrective_action_label")
  evidenceLabel         String        @map("evidence_label")
  blockers              String[]      @default([])
  warnings              String[]      @default([])
  openedAt              DateTime      @map("opened_at") @db.Timestamptz(6)
  dueAt                 DateTime      @map("due_at") @db.Timestamptz(6)
  resolvedAt            DateTime?     @map("resolved_at") @db.Timestamptz(6)
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization          Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  serviceOrder          ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  ownerUser             AppUser?      @relation(fields: [ownerUserId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  nonconformingWorkCases NonconformingWorkCase[]

  @@unique([organizationId, title])
  @@index([organizationId, status, dueAt])
  @@index([organizationId, serviceOrderId])
  @@map("nonconformities")
  @@schema("public")
}

