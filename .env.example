# Aferê — variáveis raiz (usadas por docker-compose dev)
# Copie para .env e ajuste.

# Postgres (compose dev)
POSTGRES_USER=afere
POSTGRES_PASSWORD=afere
POSTGRES_DB=afere

# Apps/api
# DATABASE_URL é a URL padrão (usada como fallback de auth/owner em dev).
# DATABASE_APP_URL deve apontar para a role afere_app (sem bypass RLS) em produção/teste.
# DATABASE_OWNER_URL é para migrations/seed (role owner/superuser).
# O tenant context RLS usa app.current_organization_id transacional via withTenant().
DATABASE_URL=postgresql://afere:afere@postgres:5432/afere?schema=public
DATABASE_APP_URL=postgresql://afere_app:afere_app@postgres:5432/afere?schema=public
DATABASE_OWNER_URL=postgresql://afere:afere@postgres:5432/afere?schema=public
REDIS_URL=redis://redis:6379

# Apps web/portal
# AFERE_API_BASE_URL=http://127.0.0.1:3000
# AFERE_PUBLIC_API_BASE_URL=http://127.0.0.1:3000
