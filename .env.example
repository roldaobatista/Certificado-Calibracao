# Aferê — variáveis raiz (usadas por docker-compose dev)
# Copie para .env e ajuste.

# Postgres (compose dev)
POSTGRES_USER=afere
POSTGRES_PASSWORD=afere
POSTGRES_DB=afere

# Overrides opcionais para apps/api — normalmente já batidos no docker-compose.yml
# DATABASE_URL=postgresql://afere:afere@postgres:5432/afere?schema=public
# REDIS_URL=redis://redis:6379
#
# RLS runtime readiness:
# - DATABASE_OWNER_URL é para migrations/seed e pode ser owner/superuser em dev.
# - DATABASE_APP_URL é a role de aplicação futura, sem bypass RLS.
# - DATABASE_URL permanece owner-only no compose dev até existir contexto transacional
#   por tenant em app.current_organization_id para login, sessão, bootstrap e CRUD.
# - Não ativar FORCE ROW LEVEL SECURITY nem DATABASE_URL=DATABASE_APP_URL sem passar
#   por specs/0099-rls-runtime-role-readiness.md.
# DATABASE_OWNER_URL=postgresql://afere:afere@postgres:5432/afere?schema=public
# DATABASE_APP_URL=postgresql://afere_app:afere_app@postgres:5432/afere?schema=public

# Apps web/portal
# AFERE_API_BASE_URL=http://127.0.0.1:3000
# AFERE_PUBLIC_API_BASE_URL=http://127.0.0.1:3000
