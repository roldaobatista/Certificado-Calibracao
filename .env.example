# .env.example — modelo de variáveis de ambiente
# Copiar pra .env e preencher (NÃO commitar .env — está no .gitignore).
# Hook secrets-scanner permite este nome especificamente; bloqueia se aparecer token real aqui.
#
# Status atual (2026-05-17): Foundation F-A ainda não começou.
# Variáveis abaixo são propostas baseadas na ADR-0001 candidata.
# Atualizar quando código existir.

# === Django ===
DEBUG=true                                    # false em produção
SECRET_KEY=substituir-em-producao             # 50+ chars aleatórios
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://app_user:senha@localhost:5432/afere_dev
TIME_ZONE=America/Sao_Paulo
LANGUAGE_CODE=pt-br

# === PostgreSQL (Docker compose local) ===
POSTGRES_DB=afere_dev
POSTGRES_USER=app_user                        # NOBYPASSRLS (INV-TENANT-004)
POSTGRES_PASSWORD=senha-local-dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Procrastinate (filas) ===
PROCRASTINATE_DATABASE_URL=${DATABASE_URL}

# === LLM Gateway (LiteLLM self-hosted) ===
LITELLM_URL=http://localhost:4000
ANTHROPIC_API_KEY=substituir-com-secret-manager

# === Storage (Backblaze B2) — DORMENTE até deploy autorizado ===
B2_KEY_ID=substituir
B2_APPLICATION_KEY=substituir
B2_BUCKET_NAME=afere-worm

# === KMS (AWS) — DORMENTE até deploy autorizado ===
AWS_REGION=sa-east-1
AWS_KMS_KEY_ARN=substituir
AWS_ACCESS_KEY_ID=substituir
AWS_SECRET_ACCESS_KEY=substituir

# === Observabilidade — DORMENTE até deploy ===
GRAFANA_CLOUD_API_KEY=substituir
AXIOM_TOKEN=substituir
SENTRY_DSN=substituir

# === Fiscal (PlugNotas) — quando Wave A começar ===
PLUGNOTAS_API_KEY=substituir
PLUGNOTAS_SANDBOX=true

# === Assinatura ICP-Brasil (Lacuna Web PKI) — Wave A ===
LACUNA_LICENSE=substituir

# === WhatsApp BSP — quando F-E começar ===
WHATSAPP_BSP_PROVIDER=                        # take-blip | gupshup | meta-direct
WHATSAPP_API_KEY=substituir
WHATSAPP_PHONE_NUMBER_ID=substituir

# === GitHub (CI) ===
GITHUB_TOKEN=substituir-com-secret-manager
