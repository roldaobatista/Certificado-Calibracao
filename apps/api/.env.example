# Aferê apps/api — variáveis de ambiente de exemplo
# Copie para .env (git-ignored) e ajuste valores para seu setup local.

NODE_ENV=development
LOG_LEVEL=debug

# HTTP
HOST=0.0.0.0
PORT=3000

# CORS (CSV de origens permitidas em dev; em prod vem do deploy config)
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# Postgres (docker compose dev — host:5433 → container:5432)
DATABASE_URL=postgresql://afere:afere@localhost:5433/afere?schema=public

# Redis (docker compose dev — host:6380 → container:6379)
REDIS_URL=redis://localhost:6380
