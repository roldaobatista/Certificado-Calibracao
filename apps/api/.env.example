# Aferê apps/api — variáveis de ambiente de exemplo
# Copie para .env (git-ignored) e ajuste valores para seu setup local.
# Em produção, DATABASE_APP_URL e DATABASE_OWNER_URL são obrigatórias.

NODE_ENV=development
LOG_LEVEL=debug

# HTTP
HOST=0.0.0.0
PORT=3000

# CORS (CSV de origens permitidas em dev; em prod vem do deploy config)
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# Postgres (docker compose dev — host:5433 → container:5432)
# DATABASE_URL é fallback dev; em produção use DATABASE_APP_URL (role RLS) e DATABASE_OWNER_URL (migrations).
DATABASE_URL=postgresql://afere:afere@localhost:5433/afere?schema=public
DATABASE_APP_URL=postgresql://afere_app:afere_app@localhost:5433/afere?schema=public
DATABASE_OWNER_URL=postgresql://afere:afere@localhost:5433/afere?schema=public

# Redis (docker compose dev — host:6380 → container:6379)
REDIS_URL=redis://localhost:6380

# Segurança (mínimo 32 caracteres; em produção não pode ser o valor de exemplo)
COOKIE_SECRET=change-me-in-production-32-chars-min

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Redirect allowlist (CSV de paths permitidos para reply.redirect)
REDIRECT_ALLOWLIST=/auth/login,/auth/logout,/onboarding,/emission/workspace,/emission/review-signature,/emission/signature-queue,/dashboard

# Feature flags
# Em produção, scenario routes devem estar desabilitados.
ALLOW_SCENARIO_ROUTES=false
# Bootstrap só deve estar habilitado na primeira instalação controlada.
BOOTSTRAP_ENABLED=true
