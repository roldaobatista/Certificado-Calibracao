{
  "name": "afere",
  "version": "0.0.1",
  "private": true,
  "description": "Aferê — plataforma metrológica de certificação de calibração (ISO/IEC 17025, Inmetro/Cgcre)",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:tools": "tsx --test apps/api/src/infra/*.test.ts apps/api/src/domain/**/*.test.ts apps/api/src/tests/**/*.test.ts apps/android/src/*.test.ts apps/web/src/**/*.test.ts apps/portal/src/**/*.test.ts tools/*.test.ts packages/db/tools/tenant-lint/src/*.test.ts packages/audit-log/src/*.test.ts packages/normative-rules/src/*.test.ts packages/engine-uncertainty/src/*.test.ts packages/ownership-lint/src/*.test.ts",
    "test:ac": "tsx --test evals/ac/*.test.ts",
    "test:regulatory": "tsx --test evals/regulatory/*.test.ts",
    "test:rls": "tsx --test evals/tenancy/rls/*.test.ts",
    "test:fuzz": "tsx --test evals/tenancy/fuzz/*.test.ts",
    "test:sync-simulator": "tsx --test evals/sync-simulator/*.test.ts",
    "test:tenancy": "pnpm test:rls && pnpm test:fuzz",
    "test:integration": "pnpm exec tsx --test apps/api/src/tests/integration/*.test.ts",
    "test:security": "pnpm exec tsx --test apps/api/src/tests/security/*.test.ts",
    "test:e2e:web": "pnpm --filter @afere/web exec playwright test",
    "test:e2e:portal": "pnpm --filter @afere/portal exec playwright test",
    "test:e2e": "pnpm test:e2e:web && pnpm test:e2e:portal",
    "dev:deps": "docker compose up -d postgres redis",
    "dev:api": "pnpm --filter @afere/api dev",
    "dev:web": "pnpm --filter @afere/web dev -- --hostname 127.0.0.1 --port 3002",
    "dev:portal": "pnpm --filter @afere/portal dev -- --hostname 127.0.0.1 --port 3003",
    "db:generate": "pnpm --filter @afere/db prisma:generate",
    "db:migrate": "pnpm --filter @afere/db prisma:migrate:deploy",
    "db:seed": "pnpm --filter @afere/db seed",
    "copy-lint:check": "pnpm --filter @afere/copy-lint exec node --import tsx src/cli.ts",
    "tenant-lint": "tsx packages/db/tools/tenant-lint/src/cli.ts",
    "rls-policy-check": "tsx tools/rls-policy-check.ts",
    "rls-runtime-readiness-check": "tsx tools/rls-runtime-readiness-check.ts",
    "audit-chain:verify": "tsx packages/audit-log/src/cli.ts",
    "worm-check": "tsx tools/worm-check.ts",
    "governance-gate": "tsx tools/governance-gate.ts",
    "escalation-check": "tsx tools/escalation-check.ts",
    "external-auditors-gate": "tsx tools/external-auditors-gate.ts",
    "roadmap-check": "tsx tools/roadmap-check.ts",
    "roadmap-backlog-check": "tsx tools/roadmap-backlog-check.ts",
    "sync-simulator-check": "tsx tools/sync-simulator-check.ts",
    "cloud-agents-policy-check": "tsx tools/cloud-agents-policy-check.ts",
    "compliance-structure-check": "tsx tools/compliance-structure-check.ts",
    "agent-frontmatter-check": "tsx tools/agent-frontmatter-check.ts",
    "slash-commands-check": "tsx tools/slash-commands-check.ts",
    "harness-design-tier3-check": "tsx tools/harness-design-tier3-check.ts",
    "harness-dashboard:check": "tsx tools/harness-dashboard.ts check",
    "harness-dashboard:write": "tsx tools/harness-dashboard.ts write",
    "runbook-check": "tsx tools/runbook-check.ts",
    "verification-cascade:check": "tsx tools/verification-cascade.ts check",
    "verification-cascade:plan": "tsx tools/verification-cascade.ts plan",
    "verification-cascade:issue-drafts": "tsx tools/verification-cascade.ts issue-drafts",
    "snapshot-diff:write-current": "tsx tools/certificate-snapshots.ts write-current",
    "snapshot-diff:sync": "tsx tools/certificate-snapshots.ts sync",
    "snapshot-diff-check": "pnpm snapshot-diff:write-current && tsx tools/verification-cascade.ts check",
    "redundancy-check": "tsx tools/redundancy-check.ts check",
    "redundancy-check:plan": "tsx tools/redundancy-check.ts plan",
    "redundancy-check:trace": "tsx tools/redundancy-check.ts trace",
    "budget:check": "tsx tools/budget-tracker.ts check",
    "budget:record": "tsx tools/budget-tracker.ts record",
    "budget:control": "tsx tools/budget-tracker.ts control",
    "budget:weekly": "tsx tools/budget-tracker.ts weekly-report",
    "normative-package:kms-sign": "tsx tools/normative-package-kms-sign.ts",
    "validation-dossier:check": "tsx tools/validation-dossier.ts check",
    "validation-dossier:write": "tsx tools/validation-dossier.ts generate",
    "emit-cert-dry": "tsx tools/emit-cert-dry.ts",
    "sync:agents": "tsx tools/sync-agents.ts",
    "sync:agents:check": "tsx tools/sync-agents.ts --check",
    "clean": "turbo run clean && rm -rf node_modules",
    "check:drift": "tsx tools/check-agents-drift.ts",
    "check:all": "pnpm typecheck && pnpm test:tools && pnpm test:ac && pnpm test:regulatory && pnpm copy-lint:check && pnpm tenant-lint && pnpm test:tenancy && pnpm rls-policy-check && pnpm rls-runtime-readiness-check && pnpm test:sync-simulator && pnpm worm-check && pnpm governance-gate && pnpm escalation-check && pnpm external-auditors-gate && pnpm roadmap-check && pnpm roadmap-backlog-check && pnpm sync-simulator-check && pnpm cloud-agents-policy-check && pnpm compliance-structure-check && pnpm agent-frontmatter-check && pnpm slash-commands-check && pnpm harness-design-tier3-check && pnpm harness-dashboard:check && pnpm runbook-check && pnpm snapshot-diff-check && pnpm redundancy-check && pnpm budget:check && tsx tools/validation-dossier.ts check --quiet && pnpm sync:agents:check && pnpm check:drift"
  },
  "pnpm": {
    "overrides": {
      "zod": "3.23.8",
      "@trpc/server": "11.0.0-rc.660"
    }
  },
  "devDependencies": {
    "@afere/audit-log": "workspace:*",
    "@afere/contracts": "workspace:*",
    "@afere/db": "workspace:*",
    "@afere/engine-uncertainty": "workspace:*",
    "@afere/normative-rules": "workspace:*",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.2",
    "js-yaml": "^4.1.0",
    "tsx": "^4.19.2",
    "turbo": "^2.3.0",
    "typescript": "^5.5.4"
  }
}
