            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/frontmatter-revisado-em-check.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/spec-ac-binario-check.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/seed-anti-pii-real.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/INV-checker.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
